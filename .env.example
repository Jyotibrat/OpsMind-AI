# ─────────────────────────────────────────────────────────
#  OpsMind AI  —  Environment Variables
#  Copy this file to .env and fill in your real values.
#  NEVER commit your .env file to version control.
# ─────────────────────────────────────────────────────────

# Google Gemini API Key
# Obtain from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# MongoDB Atlas Connection String (SRV format)
# Example: mongodb+srv://user:password@cluster.mongodb.net/
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/

# ── Optional Overrides (defaults shown) ──────────────────

# MongoDB database name
DB_NAME=opsmind_ai

# MongoDB collection name for document chunks
COLLECTION_NAME=document_chunks

# Log collection name
LOG_COLLECTION=query_logs

# Minimum cosine similarity score to use a retrieved chunk
SIMILARITY_THRESHOLD=0.75

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate a strong random key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-secret-in-production
TOKEN_EXPIRE_HOURS=8

# Default user credentials (change these before deploying!)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
EMPLOYEE_USERNAME=employee
EMPLOYEE_PASSWORD=employee123

# Number of chunks to retrieve from vector search
TOP_K=5
